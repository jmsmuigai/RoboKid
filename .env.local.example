# RoboKid Platform — Environment Variables
# Copy this file to .env.local and fill in your keys
# ⚠️ NEVER commit .env.local — it's git-ignored

# Google Gemini API (required for AI content generation & translation)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_google_api_key_here

# Firebase Configuration (for database, auth, and hosting)
# Get these from: https://console.firebase.google.com → Project Settings → General
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=robokid-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=robokid-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=robokid-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000:web:000
